{
  "name": "anomaly_detection_and_dispatch_bt",
  "title": "智能质差识别与定界派单树",
  "description": "质差检测与预警解耦，利用Sequence原生熔断机制处理流程退出",
  "type": "parallel",
  "children": [
    {
      "name": "main_workflow_sequence",
      "title": "全流程主干",
      "description": "",
      "type": "sequence",
      "children": [
        {
          "name": "detect_anomaly",
          "title": "节点①：质差识别检测",
          "description": "内部逻辑：若未发现质差则返回 Failure（自动结束流程），有质差则返回 Success 往下推进",
          "type": "action",
          "func": {
            "type": "ces_tool",
            "schema": {
              "name": "detect_anomaly"
            }
          }
        },
        {
          "name": "generate_anomaly_alert",
          "title": "节点②：质差预警与聚合",
          "description": "内部逻辑：聚合事件，若未达阈值返回 Failure（自动结束流程），达标则生成预警并返回 Success",
          "type": "action",
          "func": {
            "type": "ces_tool",
            "schema": {
              "name": "generate_anomaly_alert"
            }
          }
        },
        {
          "name": "execute_fault_localization",
          "title": "节点③：智能定界定位分析",
          "description": "内部逻辑：包含映射表配置、40%占比阈值及明确结论等策略分流，最终完成定界",
          "type": "action",
          "func": {
            "type": "ces_tool",
            "schema": {
              "name": "execute_fault_localization"
            }
          }
        },
        {
          "name": "invoke_domain_diagnostics",
          "title": "第三阶段：调用外部专业能力",
          "description": "获取专业系统的修复结果与诊断信息",
          "type": "action",
          "func": {
            "type": "ces_tool",
            "schema": {
              "name": "invoke_domain_diagnostics"
            }
          }
        },
        {
          "name": "selector_repair_result",
          "title": "修复结果分流(Selector)",
          "description": "决定是直接验证闭环，还是继续跨域派单",
          "type": "selector",
          "children": [
            {
              "name": "seq_repair_success",
              "title": "修复达标分支",
              "description": "",
              "type": "sequence",
              "children": [
                {
                  "name": "check_repair_success",
                  "title": "修复达标(Condition)",
                  "description": "",
                  "type": "action",
                  "func": {
                    "type": "ces_tool",
                    "schema": {
                      "name": "check_repair_success"
                    }
                  }
                },
                {
                  "name": "invoke_verification_agent",
                  "title": "触发闭环验证智能体",
                  "description": "调起节点⑥行为树进行闭环验证，本流程结束",
                  "type": "action",
                  "func": {
                    "type": "ces_tool",
                    "schema": {
                      "name": "invoke_verification_agent"
                    }
                  }
                }
              ]
            },
            {
              "name": "seq_cross_domain_dispatch",
              "title": "未达标跨域派单分支(兜底)",
              "description": "",
              "type": "sequence",
              "children": [
                {
                  "name": "execute_cross_domain_and_dispatch",
                  "title": "节点④：跨域排查与新建质差单",
                  "description": "内部包含第四、第五阶段及派单方式(EMOS/其他)分流，最终完成建单",
                  "type": "action",
                  "func": {
                    "type": "ces_tool",
                    "schema": {
                      "name": "execute_cross_domain_and_dispatch"
                    }
                  }
                }
              ]
            }
          ]
        }
      ]
    }
  ],
  "policy": "SuccessOnOne"
}